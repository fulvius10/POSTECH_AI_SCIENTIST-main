-- ============================================================
SELECT 
_quarentena_motivo AS motivo,
COUNT(*)  AS total
FROM datalake_demo.transacoes_vendas_quarentena
WHERE anomesdia = '20260322'
GROUP BY _quarentena_motivo
ORDER BY total DESC

-- ============================================================
-- 5. PASS — registros validos prontos para analise
-- ============================================================

-- Distribuicao por categoria
SELECT
    categoria,
    COUNT(*)                                                        AS total_transacoes,
    CONCAT('R$ ', FORMAT('%.2f', ROUND(SUM(valor_total), 2)))       AS receita_total,
    CONCAT('R$ ', FORMAT('%.2f', ROUND(AVG(valor_total), 2)))       AS ticket_medio,
    CONCAT(CAST(ROUND(AVG(desconto_pct), 1) AS VARCHAR), '%')       AS desconto_medio
FROM datalake_demo.transacoes_vendas_pass
WHERE anomesdia = '20260322'
GROUP BY categoria
ORDER BY SUM(valor_total) DESC;

-- Top 10 produtos por receita
SELECT
    produto,
    categoria,
    COUNT(*)                                                        AS total_vendas,
    SUM(quantidade)                                                 AS total_itens,
    CONCAT('R$ ', FORMAT('%.2f', ROUND(SUM(valor_total), 2)))       AS receita_total
FROM datalake_demo.transacoes_vendas_pass
WHERE anomesdia = '20260322'
GROUP BY produto, categoria
ORDER BY SUM(valor_total) DESC
LIMIT 10;


