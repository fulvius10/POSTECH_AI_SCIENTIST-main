-- 2. VALIDAÇÃO — conferir que os dados chegaram
-- ============================================================

SELECT 'bronze'     AS camada, COUNT(*) AS total FROM datalake_demo.transacoes_vendas_bronze     WHERE anomesdia = '20260322'
UNION ALL
SELECT 'quarentena' AS camada, COUNT(*) AS total FROM datalake_demo.transacoes_vendas_quarentena WHERE anomesdia = '20260322'
UNION ALL
SELECT 'pass'       AS camada, COUNT(*) AS total FROM datalake_demo.transacoes_vendas_pass       WHERE anomesdia = '20260322'
