-- Receita por categoria
SELECT
    categoria,
    total_transacoes,
    CONCAT('R$ ', FORMAT('%.2f', receita_total))                    AS receita_total,
    CONCAT('R$ ', FORMAT('%.2f', ticket_medio))                     AS ticket_medio,
    itens_vendidos,
    CONCAT(CAST(ROUND(desconto_medio_pct, 1) AS VARCHAR), '%')      AS desconto_medio,
    lojas_ativas
FROM datalake_demo.transacoes_vendas_gold_por_categoria
WHERE anomesdia = '20260322'
ORDER BY receita_total DESC;

-- Receita por regiao
SELECT
    regiao,
    total_transacoes,
    CONCAT('R$ ', FORMAT('%.2f', receita_total))                    AS receita_total,
    CONCAT('R$ ', FORMAT('%.2f', ticket_medio))                     AS ticket_medio,
    clientes_unicos,
    lojas_ativas
